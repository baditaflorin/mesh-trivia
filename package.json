{
  "name": "mesh-trivia",
  "version": "0.1.1",
  "description": "Peer-to-peer mesh: Kahoot-style trivia. Mesh-time synchronized reveal; fair first-to-answer scoring. Unlimited players, free.",
  "type": "module",
  "private": false,
  "homepage": "https://baditaflorin.github.io/mesh-trivia/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/mesh-trivia.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/mesh-trivia/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "bash scripts/build-pages.sh",
    "preview": "vite preview --host 0.0.0.0",
    "pages-preview": "vite preview --host 0.0.0.0 --port 4174",
    "test": "npm run test:unit && npm run test:e2e",
    "smoke": "bash scripts/smoke.sh",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.27",
    "@baditaflorin/mesh-common": "file:../mesh-common"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^2.1.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^26.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
