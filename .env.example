VITE_APP_VERSION=0.1.0
VITE_GIT_COMMIT=local
VITE_REPOSITORY_URL=https://github.com/baditaflorin/mesh-trivia

# Self-hosted signaling endpoint (y-webrtc protocol).
VITE_WEBRTC_SIGNALING=wss://turn.0docker.com/ws

# Self-hosted TURN credential endpoint.
# The URL is not a secret. Only TURN_SECRET on the server is.
VITE_TURN_TOKEN_URL=https://turn.0docker.com/credentials
